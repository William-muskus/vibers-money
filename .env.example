# --- Auth (NextAuth) — required for frontend ---
# Generate: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_at_least_32_chars
# GitHub OAuth: https://github.com/settings/developers
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# Google OAuth: https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# Magic link (email): https://resend.com — add domain and create API key. When set, login page shows "Send magic link".
# AUTH_RESEND_KEY=re_xxxx
# Sender address (must use a domain verified in Resend). Default: vibers.money <onboarding@resend.dev>
# EMAIL_FROM="vibers.money <noreply@yourdomain.com>"

# Mistral API key (required for agents unless using Local LLM or Bedrock)
MISTRAL_API_KEY=your_key_here

# --- Observability (optional) ---
# Sentry: set in frontend (NEXT_PUBLIC_SENTRY_DSN) and/or orchestrator (SENTRY_DSN)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# Structured logs: LOG_JSON=1 for one-JSON-object-per-line (Docker, Axiom, etc.)
# LOG_JSON=1

# --- Swarm Bus persistence (optional) ---
# When set, swarm-bus stores agent registry and message inboxes in Redis (survives restarts).
# When unset, swarm-bus uses in-memory storage (fine for local dev).
# REDIS_URL=redis://localhost:6379
# Wake engine: if orchestrator reports the agent mid–Vibe, retry POST after this many ms (default 30000).
# WAKE_BUSY_RETRY_MS=30000

# --- Local LLM (optional) ---
# When set, agents use an OpenAI-compatible local server; no MISTRAL_API_KEY needed.
# All agents share one server — requests queue; latency may increase with many concurrent agents.
# llama.cpp (default): run "npm run dev:inference", then set LOCAL_LLM_API_BASE and model paths.
LOCAL_LLM_ENGINE=llama-cpp
LOCAL_LLM_API_BASE=http://localhost:8080/v1
MODEL_PATH=models/Qwen3.5-4B-Claude-4.6-Opus-Reasoning-Distilled-Q4_K_M.gguf
DRAFT_MODEL_PATH=models/Qwen3.5-0.8B-Claude-4.6-Opus-Reasoning-Distilled-Q4_K_M.gguf
# 1 = load draft for speculative decoding (if llama.cpp supports your model). 0 = main only (saves VRAM; Qwen3.5 hybrid often disables speculative draft anyway).
# LLAMA_LOAD_DRAFT=0
LLAMA_CPP_PATH=
# 32k+ recommended for agent loops (tool calls + chat). Smaller n_ctx (e.g. 8192–16384) improves tok/s if sessions stay compact. Below ~16k you may see truncation.
LLAMA_CONTEXT_SIZE=32768
# Mistral Vibe only: auto-compact session history at this token count (AutoCompactMiddleware). When LOCAL_LLM_* is set, orchestrator defaults to floor(0.75 * LLAMA_CONTEXT_SIZE) in generated .vibe/config.toml unless you override here.
# VIBE_AUTO_COMPACT_THRESHOLD=
# llama-server -np: parallel slots. Omit for server default (auto). Use 1 for best single-stream tok/s; raise (e.g. 4) only if many agents hit the server at once.
# LLAMA_PARALLEL=1
# GPU layers: "all" (default) or a number. Replaces legacy -ngl 99.
# LLAMA_N_GPU_LAYERS=all
# KV cache quant: q4_0 saves VRAM; f16 often faster on GPU if memory allows.
# LLAMA_CACHE_TYPE_K=q4_0
# LLAMA_CACHE_TYPE_V=q4_0
# Optional: flash-attn on|off|auto (default on).
# LLAMA_FLASH_ATTN=on
# Optional: batch sizes (defaults: -b 2048, -ub 512 in llama.cpp).
# LLAMA_BATCH=
# LLAMA_UBATCH=
# Optional: CPU threads for gen / prefill (helps CPU offload or prefill-bound runs).
# LLAMA_THREADS=
# LLAMA_THREADS_BATCH=
# Optional: disable embedded Web UI / enable --perf timings in logs.
# LLAMA_NO_WEBUI=1
# LLAMA_PERF=1
# Draft speculative decoding (when LLAMA_LOAD_DRAFT=1): GPU layers for draft model.
# LLAMA_N_GPU_LAYERS_DRAFT=all
# LLAMA_DRAFT_MAX=16
# LLAMA_DRAFT_MIN=5
# Optional: override model id for health/requests (default: derived from MODEL_PATH stem).
# LOCAL_LLM_MODEL=
# Optional: for usage recording and session URL, set:
# RECORD_INFERENCE_USAGE=1
# ORCHESTRATOR_PUBLIC_URL=http://localhost:3000
# Other backends: Ollama LOCAL_LLM_API_BASE=http://localhost:11434/v1, LOCAL_LLM_MODEL=mistral:7b

# Mistral Vibe CLI (required when "vibe" is not on PATH)
# Using py launcher (pip install mistral-vibe with py -3):
#   Get path: py -3 -c "import sys, os; print(os.path.join(os.path.dirname(sys.executable), 'Scripts', 'vibe.exe'))"
#   Then set VIBE_CLI to that path, or use:
# VIBE_CLI=py -3 -m mistral_vibe
# Or full path, e.g.:
# VIBE_CLI=C:\Users\You\AppData\Local\Programs\Python\Python312\Scripts\vibe.exe
# Or with uv: VIBE_CLI=uv run vibe
# When using VIBE_USE_PYTHON_MODULE=1, if "py" is not in PATH (e.g. Node spawn on Windows), set:
# VIBE_PYTHON=python
# Or full path: VIBE_PYTHON=C:\Users\You\AppData\Local\Programs\Python\Python312\python.exe

# --- Stripe (funding per business) ---
# Required for /api/stripe/checkout and /api/stripe/webhook.
# Get keys: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_..., sk_test_...) for local dev.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Webhook signing secret from Stripe CLI or Dashboard (Developers → Webhooks).
# Local: stripe listen --forward-to localhost:3001/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Optional: base URL for checkout success/cancel redirects (default: http://localhost:3001)
# NEXT_PUBLIC_APP_URL=http://localhost:3001
# Optional: platform fee in cents per payment (e.g. 50 = $0.50). Only when business has Connect; 0 = full amount to business.
# STRIPE_APPLICATION_FEE_CENTS=200
# Optional: path to JSON file storing Connect account IDs per business (default: ./data/stripe-connect.json). For serverless use a DB or KV and adapt lib/stripe-connect-store.ts.
# STRIPE_CONNECT_DATA_PATH=./data/stripe-connect.json

# --- Computer Use (browser control for agents) ---
# `npm run dev:computer-use` loads repo-root .env, starts Chrome with --remote-debugging-port (local CDP only), then the MCP on :3200 — if nothing is listening on CDP_PORT yet.
# Set `COMPUTER_USE_AUTO_CHROME=0` to never auto-launch Chrome (you start Chrome yourself).
# Remote Chrome: set `CDP_HOST` to that machine (e.g. 192.168.1.10); auto-launch is skipped. Ensure Chrome there uses `--remote-debugging-port=9222` and firewall allows it.
# CDP_HOST=localhost
# CDP_PORT=9222
# CHROME_PATH=   # optional; default Google Chrome path per OS
# CHROME_USER_DATA_DIR=   # optional; default ~/.vibers-computer-use-chrome-profile
