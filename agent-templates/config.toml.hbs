# Vibe config for {{business_id}}/{{role}}
# Generated by Orchestrator — do not set system_prompt_id; Vibe uses default + AGENTS.md
# Dev roles (product-director, cto, security-director) use Devstral; others use Mistral Small.

enable_auto_update = false
active_model = "{{active_model}}"

# Devstral Small 2 — for dev roles (code, architecture, technical policies)
[[models]]
name = "labs-devstral-small-2512"
provider = "mistral"
alias = "labs-devstral-small-2512"
temperature = 0.2
input_price = 0.1
output_price = 0.3
thinking = "off"

# Mistral Small — for non-dev roles (CEO, marketing, finance)
[[models]]
name = "mistral-small-2501"
provider = "mistral"
alias = "mistral-small-2501"
temperature = 0.3
input_price = 0.05
output_price = 0.15
thinking = "off"

# CEO runs in programmatic/streaming mode; ask_user_question requires interactive UI.
# CEO asks questions as regular message content instead; founder replies via chat.
{{#if is_ceo}}
disabled_tools = ["ask_user_question"]
{{/if}}
enable_telemetry = false
auto_approve = true

# Tool permissions: allow Swarm Bus and Computer Use MCP tools
[tool_permissions]
default = "allow"

# Swarm Bus: X-Agent-Id and X-Business-Id are required for inbox/messaging (identity = business_id--agent_role).
[[mcp_servers]]
name = "swarm-bus"
transport = "http"
url = "{{swarm_bus_url}}"
headers = { "X-Agent-Id" = "{{agent_role}}", "X-Business-Id" = "{{business_id}}" }

[[mcp_servers]]
name = "computer-use"
transport = "http"
url = "{{computer_use_url}}"
headers = { "X-Agent-Id" = "{{agent_role}}", "X-Business-Id" = "{{business_id}}" }
