# Vibe config for {{business_id}}/{{role}}
# Generated by Orchestrator — do not set system_prompt_id; Vibe uses default + AGENTS.md
# When use_local=true: OpenAI-compatible local server (Ollama, vLLM, llama.cpp). When use_bedrock=true: AWS Bedrock gateway. Else: Mistral API.

enable_auto_update = false
active_model = "{{active_model}}"
{{#if has_auto_compact_threshold}}
# Auto-compact Vibe session history (AutoCompactMiddleware). With local LLM, default is 75% of LLAMA_CONTEXT_SIZE from orchestrator env; override with VIBE_AUTO_COMPACT_THRESHOLD.
auto_compact_threshold = {{auto_compact_threshold}}
{{/if}}

{{#if use_local}}
# Local LLM (Ollama / vLLM / llama.cpp) — all agents share this server; requests queue.
[[providers]]
name = "local"
api_base = "{{local_api_base}}"
api_style = "openai"
backend = "generic"

[[models]]
name = "{{local_model_name}}"
provider = "local"
alias = "{{local_model_alias}}"
temperature = 0.3
input_price = 0.0
output_price = 0.0
thinking = "off"
{{else}}
{{#if use_bedrock}}
# AWS Bedrock via OpenAI-compatible gateway (uses BEDROCK_GATEWAY_API_KEY env)
[[providers]]
name = "bedrock"
api_base = "{{bedrock_gateway_url}}"
api_key_env_var = "BEDROCK_GATEWAY_API_KEY"
api_style = "openai"
backend = "generic"

# Mistral Small on Bedrock — same roles as mistral-small
[[models]]
name = "mistral.mistral-small-2402-v1:0"
provider = "bedrock"
alias = "mistral-small-bedrock"
temperature = 0.3
input_price = 0.0
output_price = 0.0
thinking = "off"

# Mistral Large on Bedrock — optional for heavier tasks
[[models]]
name = "mistral.mistral-large-2407-v1:0"
provider = "bedrock"
alias = "mistral-large-bedrock"
temperature = 0.2
input_price = 0.0
output_price = 0.0
thinking = "off"
{{else}}
# Devstral Small 2 — for dev roles (code, architecture, technical policies)
[[models]]
name = "labs-devstral-small-2512"
provider = "mistral"
alias = "labs-devstral-small-2512"
temperature = 0.2
input_price = 0.1
output_price = 0.3
thinking = "off"

# Mistral Small — for non-dev roles (CEO, marketing, finance)
[[models]]
name = "mistral-small"
provider = "mistral"
alias = "mistral-small"
temperature = 0.3
input_price = 0.2
output_price = 0.6
thinking = "off"
{{/if}}
{{/if}}

# Programmatic NDJSON streaming — interactive ask_user_question is disabled for all agents (including CEO).
disabled_tools = ["ask_user_question"]

enable_telemetry = false
auto_approve = true

# Tool permissions: allow Swarm Bus and Computer Use MCP tools
[tool_permissions]
default = "allow"

# Swarm Bus: X-Agent-Id and X-Business-Id are required for inbox/messaging (identity = business_id--agent_role).
[[mcp_servers]]
name = "swarm-bus"
transport = "http"
url = "{{swarm_bus_url}}"
headers = { "X-Agent-Id" = "{{agent_role}}", "X-Business-Id" = "{{business_id}}" }

[[mcp_servers]]
name = "computer-use"
transport = "http"
url = "{{computer_use_url}}"
headers = { "X-Agent-Id" = "{{agent_role}}", "X-Business-Id" = "{{business_id}}" }

{{#if is_ceo}}
# Runtime control: set_awaiting_founder(wait) — same host as orchestrator (ORCHESTRATOR_URL).
[[mcp_servers]]
name = "orchestrator"
transport = "http"
url = "{{orchestrator_mcp_url}}"
headers = { "X-Agent-Id" = "{{agent_role}}", "X-Business-Id" = "{{business_id}}" }
{{/if}}
